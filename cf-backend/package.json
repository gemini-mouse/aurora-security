{
  "name": "alarm-telegram-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/wrangler/bin/wrangler.js dev",
    "deploy": "node ./node_modules/wrangler/bin/wrangler.js deploy",
    "db:init": "node ./node_modules/wrangler/bin/wrangler.js d1 execute alarm-db --local --file=./schema.sql",
    "db:init:remote": "node ./node_modules/wrangler/bin/wrangler.js d1 execute alarm-db --remote --file=./schema.sql",
    "db:migrate:device-auth": "node ./node_modules/wrangler/bin/wrangler.js d1 execute alarm-db --local --file=./migrations/001_device_auth.sql",
    "db:migrate:device-auth:remote": "node ./node_modules/wrangler/bin/wrangler.js d1 execute alarm-db --remote --file=./migrations/001_device_auth.sql"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.87.0"
  }
}
